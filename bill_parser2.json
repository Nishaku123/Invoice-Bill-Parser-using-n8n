{
  "name": "bill_parser2",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "triggerOn": "specificFolder",
        "folderToWatch": {
          "value": "YOUR_FOLDER_ID",
          "mode": "list"
        },
        "event": "fileCreated",
        "options": {}
      },
      "type": "n8n-nodes-base.googleDriveTrigger",
      "typeVersion": 1,
      "position": [0,0],
      "name": "Google Drive Trigger",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "GOOGLE_DRIVE_CREDENTIAL",
          "name": "Google Drive account"
        }
      }
    },

    {
      "parameters": {
        "operation": "download",
        "fileId": "={{ $json.id }}",
        "options": {
          "binaryPropertyName": "data"
        }
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [144,0],
      "name": "Download file",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "GOOGLE_DRIVE_CREDENTIAL",
          "name": "Google Drive account"
        }
      }
    },

    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.mimeType }}",
              "rightValue": "application/pdf",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [320,0],
      "name": "If"
    },

    {
      "parameters": {
        "documentType": "image_url"
      },
      "type": "n8n-nodes-base.mistralAi",
      "typeVersion": 1,
      "position": [544,-16],
      "name": "Extract text",
      "credentials": {
        "mistralCloudApi": {
          "id": "MISTRAL_API_CREDENTIAL",
          "name": "Mistral API"
        }
      }
    },

    {
      "parameters": {
        "text": "={{ $json.extractedText }}",
        "attributes": {
          "attributes": [
            {
              "name": "Invoice Category",
              "description": "Select from predefined options (Office Supplies, Bills, Rent)"
            },
            {
              "name": "Invoice Number"
            },
            {
              "name": "Invoice Biller"
            },
            {
              "name": "Invoice Total",
              "type": "number"
            },
            {
              "name": "Invoice Sub Total",
              "type": "number"
            },
            {
              "name": "Tax Amount",
              "type": "number"
            }
          ]
        }
      },
      "type": "@n8n/n8n-nodes-langchain.informationExtractor",
      "typeVersion": 1,
      "position": [736,-16],
      "name": "Information Extractor"
    },

    {
      "parameters": {
        "modelName": "models/gemini-2.5-flash-lite-preview-09-2025"
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [816,176],
      "name": "Google Gemini Chat Model",
      "credentials": {
        "googlePalmApi": {
          "id": "GEMINI_API_CREDENTIAL",
          "name": "Gemini API"
        }
      }
    },

    {
      "parameters": {
        "operation": "move",
        "fileId": "={{ $('Download file').item.json.id }}",
        "driveId": "My Drive",
        "folderId": "PROCESSED_FOLDER_ID"
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1056,-16],
      "name": "Move file",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "GOOGLE_DRIVE_CREDENTIAL",
          "name": "Google Drive account"
        }
      }
    },

    {
      "parameters": {
        "operation": "update",
        "fileId": "={{ $json.id }}",
        "newUpdatedFileName": "={{ $('Information Extractor').item.json.output['Invoice Biller'] }} - {{ $('Information Extractor').item.json.output['Invoice Number'] }}"
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1216,-16],
      "name": "Update file",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "GOOGLE_DRIVE_CREDENTIAL",
          "name": "Google Drive account"
        }
      }
    },

    {
      "parameters": {
        "operation": "append",
        "documentId": "YOUR_SHEET_ID",
        "sheetName": "Sheet1",
        "columns": {
          "Invoice Category": "={{ $('Information Extractor').item.json.output['Invoice Category'] }}",
          "Invoice Number": "={{ $('Information Extractor').item.json.output['Invoice Number'] }}",
          "Invoice biller": "={{ $('Information Extractor').item.json.output['Invoice Biller'] }}",
          "Invoice total": "={{ $('Information Extractor').item.json.output['Invoice Total'] }}",
          "Invoice sub total": "={{ $('Information Extractor').item.json.output['Invoice Sub Total'] }}",
          "Tax Amount": "={{ $('Information Extractor').item.json.output['Tax Amount'] }}",
          "File Name": "={{ $json.name }}",
          "File url": "=https://drive.google.com/file/d/{{ $json.id }}/view"
        }
      },
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [1376,-16],
      "name": "Append row in sheet",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CREDENTIAL",
          "name": "Google Sheets API"
        }
      }
    }
  ]
}
